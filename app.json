{
  "expo": {
    "name": "Almaarefa University",
    "slug": "almaarefa-university-app",
    "scheme": "almaarefa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FFFFFF",
    "primaryColor": "#00ADCA",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "sa.edu.um.app",
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "2"
    },
    "android": {
      "package": "sa.edu.um.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#00ADCA"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#00ADCA",
          "image": "./assets/logo-white.png",
          "imageWidth": 240
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#00ADCA"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Almaarefa to access your photos to upload menu item images."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "ad7e9167-046a-45c1-b740-3950998c02dc"
      }
    },
    "owner": "mustafarasheed",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ad7e9167-046a-45c1-b740-3950998c02dc"
    }
  }
}
