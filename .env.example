# Copy to .env and fill in. EXPO_PUBLIC_* vars are exposed to the app at build time.

# Supabase (Phase 2 — leave blank to run on seeded mock data)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# University systems opened via secure in-app WebView (SSO on their own pages)
EXPO_PUBLIC_PORTAL_URL=https://portal.um.edu.sa
EXPO_PUBLIC_MOODLE_URL=https://lms.um.edu.sa
EXPO_PUBLIC_WEBMAIL_URL=https://outlook.office.com/mail/
